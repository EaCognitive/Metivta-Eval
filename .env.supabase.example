# Supabase Configuration
# Copy this file to .env.supabase and fill in your actual values

# Your Supabase project URL
# Found in: Settings > API > Project URL
SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anonymous public key
# Found in: Settings > API > Project API keys > anon/public
SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Service role key for admin operations (keep very secure!)
# Found in: Settings > API > Project API keys > service_role
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Optional: direct Postgres connection for SQLAlchemy
DATABASE_URL=postgresql+psycopg://<db_user>:<db_password>@<db_host>:5432/<db_name>
