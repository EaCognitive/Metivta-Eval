FROM python:3.12-slim

ARG VERSION=dev

LABEL org.opencontainers.image.title="MetivtaEval FastAPI Lite"
LABEL org.opencontainers.image.description="Lean FastAPI runtime for Azure deployment"
LABEL org.opencontainers.image.version="${VERSION}"

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    build-essential \
    && rm -rf /var/lib/apt/lists/* \
    && useradd --create-home --shell /bin/bash metivta

WORKDIR /app

COPY src/ ./src
COPY api/ ./api
COPY config.toml ./config.toml
COPY pyproject.toml ./pyproject.toml

RUN pip install --no-cache-dir --upgrade pip setuptools wheel && \
    pip install --no-cache-dir \
    fastapi \
    uvicorn \
    pydantic \
    requests \
    sqlalchemy \
    "psycopg[binary]" \
    email-validator \
    python-dotenv \
    pyyaml \
    structlog \
    redis \
    celery \
    beautifulsoup4 \
    numpy \
    langchain \
    langsmith \
    langchain-anthropic \
    anthropic \
    supabase

ENV PYTHONPATH="/app/src:/app" \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

RUN mkdir -p /app/logs && chown -R metivta:metivta /app

USER metivta

EXPOSE 8001

HEALTHCHECK --interval=10s --timeout=5s --start-period=30s --retries=3 \
    CMD curl -f http://localhost:8001/health || exit 1

ENTRYPOINT ["python", "-m", "uvicorn"]
CMD ["api.fastapi_app.main:app", "--host", "0.0.0.0", "--port", "8001", "--workers", "2"]
